{
  "turbo-ai-rules.sync.onStartup": false,
  "turbo-ai-rules.sources": [
    {
      "id": "ai-rules",
      "name": "AI Rules",
      "gitUrl": "https://github.com/ygqygq2/ai-rules.git",
      "branch": "main",
      "enabled": true,
      "authentication": {
        "type": "none"
      }
    }
  ],
  "turbo-ai-rules.adapters.custom": [
    {
      "id": "test-skills",
      "name": "Test Skills Adapter",
      "enabled": true,
      "outputPath": "test-skills",
      "isRuleType": false,
      "outputType": "directory",
      "fileExtensions": [
        "*.md"
